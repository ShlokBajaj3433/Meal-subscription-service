pipeline {
    agent any

    stages {
        stage('Build') {
            steps {
                script {
                    if (isUnix()) {
                        sh 'chmod +x "$WORKSPACE/mvnw" && "$WORKSPACE/mvnw" -f meal-service/pom.xml clean install -DskipTests'
                    } else {
                        bat '"%WORKSPACE%\\mvnw.cmd" -f meal-service\\pom.xml clean install -DskipTests'
                    }
                }
            }
        }

        stage('Test') {
            steps {
                script {
                    if (isUnix()) {
                        sh '"$WORKSPACE/mvnw" -f meal-service/pom.xml test'
                    } else {
                        bat '"%WORKSPACE%\\mvnw.cmd" -f meal-service\\pom.xml test'
                    }
                }
            }
        }

        stage('Selinium TestNG') {
            steps {
                script {
                    if (isUnix()) {
                        sh '"$WORKSPACE/mvnw" -f Selinium/pom.xml test -Dapp.base.url=${APP_BASE_URL:-http://localhost:8080} -Dbrowser=${BROWSER:-chrome} -Dheadless=${HEADLESS:-true}'
                    } else {
                        bat 'if not defined APP_BASE_URL set APP_BASE_URL=http://localhost:8080 && if not defined BROWSER set BROWSER=chrome && if not defined HEADLESS set HEADLESS=true && "%WORKSPACE%\\mvnw.cmd" -f Selinium\\pom.xml test -Dapp.base.url=%APP_BASE_URL% -Dbrowser=%BROWSER% -Dheadless=%HEADLESS%'
                    }
                }
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: 'Selinium/target/surefire-reports/*.xml'
                }
            }
        }

        stage('Run') {
            steps {
                script {
                    if (isUnix()) {
                        sh 'java -jar meal-service/target/*.jar'
                    } else {
                        bat 'for %%i in (meal-service\\target\\*.jar) do java -jar "%%i"'
                    }
                }
            }
        }
    }
}
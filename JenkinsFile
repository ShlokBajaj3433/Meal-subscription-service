pipeline {
    agent any

    tools {
        maven 'Maven'   // configure in Jenkins
    }

    stages {
        stage('Clone') {
            steps {
                git 'https://github.com/ShlokBajaj3433/Meal-subscription-service.git'
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean install'
            }
        }

        stage('Test') {
            steps {
                sh 'mvn test'
            }
        }

        stage('Run') {
            steps {
                sh 'java -jar target/*.jar'
            }
        }
    }
}
pipeline {
    agent any

    stages {
        stage('Build') {
            steps {
                script {
                    if (isUnix()) {
                        sh 'chmod +x mvnw && ./mvnw -f meal-service/pom.xml clean install -DskipTests'
                    } else {
                        bat '.\\mvnw.cmd -f meal-service\\pom.xml clean install -DskipTests'
                    }
                }
            }
        }

        stage('Test') {
            steps {
                script {
                    if (isUnix()) {
                        sh './mvnw -f meal-service/pom.xml test'
                    } else {
                        bat '.\\mvnw.cmd -f meal-service\\pom.xml test'
                    }
                }
            }
        }

        stage('Run') {
            steps {
                script {
                    if (isUnix()) {
                        sh 'java -jar meal-service/target/*.jar'
                    } else {
                        bat 'for %i in (meal-service\\target\\*.jar) do java -jar "%i"'
                    }
                }
            }
        }
    }
}